# --- Required (web app) ---
# Public Supabase API (safe in browser bundle)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional (feature flags) ---
# Show the /admin/import surface. Requires a Python worker reachable at
# SRE_IMPORT_PYTHON. Leave unset/false on Vercel; set to "true" locally.
NEXT_PUBLIC_IMPORTER_ENABLED=false

# --- Importer (only if NEXT_PUBLIC_IMPORTER_ENABLED=true) ---
# Path to the python binary that has the sre-import package installed.
SRE_IMPORT_PYTHON=python
# Path to the scripts/import directory (cwd for the CLI).
# Default: <repo>/scripts/import resolved from process.cwd().
# SRE_IMPORT_DIR=

# --- E2E only (do not set in production) ---
# Used by tests/e2e/setup.ts to seed users via the auth admin API.
# In CI, mirror SUPABASE_SERVICE_ROLE_KEY here.
